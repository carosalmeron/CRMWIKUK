{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "functions": {
    "api/daily-summary.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/daily-summary",
      "schedule": "0 7 * * 1-5"
    }
  ]
}
