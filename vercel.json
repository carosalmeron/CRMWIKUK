{
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/daily-summary",
      "schedule": "5 5 * * 1-5"
    },
    {
      "path": "/api/weekly-summary",
      "schedule": "0 17 * * 5"
    }
  ]
}
